# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — HuggingFace token for speaker diarization (better multi-speaker handling)
HF_TOKEN=hf_...

# Postgres password (defaults to "clipforge" for local dev)
POSTGRES_PASSWORD=clipforge

# Whisper model size: tiny | base | small | medium | large-v3
# Larger = more accurate, slower. base is good for MVP.
WHISPER_MODEL=base
