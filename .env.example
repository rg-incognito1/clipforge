# Required — get free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Optional — HuggingFace token for speaker diarization (better multi-speaker crop)
# Get from https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Postgres password (defaults to "clipforge" for local dev)
POSTGRES_PASSWORD=clipforge

# Whisper model size: tiny | base | small | medium | large-v3
# Larger = more accurate but slower. base is good for most videos.
WHISPER_MODEL=base
